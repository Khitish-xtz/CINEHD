    "server": "node server/index.js",
    "kill-ports": "node -e \"const {execSync}=require('child_process');['3001','5173'].forEach(p=>{try{const o=execSync('netstat -ano | findstr :'+p,{encoding:'utf8'});o.split('\\n').filter(l=>l.includes('LISTEN')).forEach(l=>{const pid=l.trim().split(/\\s+/).pop();if(pid&&!isNaN(pid))try{execSync('taskkill /F /PID '+pid,{stdio:'ignore'})}catch{}});}catch{}})\"",
    "start": "node start.js"
  },
